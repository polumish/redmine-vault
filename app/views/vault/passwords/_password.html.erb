<tr class="hascontextmenu key vault-row <%= defined?(parity) ? parity : "" %>"
    data-card-url="<%= url_for(controller: 'keys', action: 'card', project_id: @project, id: password, only_path: true) %>"
    data-card-title="<%= password.name %>">
  <td class="checkbox hide-when-print">
    <%= check_box_tag("ids[]", password.id, false, id: nil) %>
  </td>
  <%= render partial: "shared/key_fields", locals: {key: password} %>
  <td class="key-password-column"<% unless password.body.blank? %> data-label="<%= t('key.attr.body') %>"<% end %>>
    <% unless password.body.blank? %>
      <label>*********</label>
      <label id="plain_pass_<%=password.id%>" style="display:none;"><%= password.body.force_encoding("UTF-8") %></label>
      <a align="left" class="keys-actions copy-key" data-clipboard-target="plain_pass_<%=password.id%>" title="<%=t("key.btn.clipboard")%>">
        <i class="fa fa-clipboard fa-fw"></i>
      </a>
    <% end %>
    <% unless password.file.blank? %>
      <a href="<%= project_preview_key_file_path(@project, password) %>" class="keys-actions vault-preview-link" title="Preview file">
        <i class="fa fa-image fa-fw"></i>
      </a>
      <a href="<%= project_download_key_file_path(@project, password) %>" class="keys-actions" title="Download file">
        <i class="fa fa-download fa-fw"></i>
      </a>
    <% end %>
  </td>
  <td class="buttons">
    <%= render partial: "shared/key_actions", locals: {key: password} %>
  </td>
</tr>
