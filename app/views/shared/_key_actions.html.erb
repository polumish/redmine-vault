<%= link_to project_key_path(@project, key), class: 'keys-actions vault-pass-link',
      data: { card_url: url_for(controller: 'keys', action: 'card', project_id: @project, id: key, only_path: true),
              card_title: key.name }, title: t('key.title.show') do %>
  <i class='fa fa-eye fa-fw'></i>
<% end %>

<% if User.current.allowed_to?(:edit_keys, @project) %>
  <%= link_to edit_project_key_path(@project, key), class: 'keys-actions', title: t('key.title.edit') do %>
    <i class='fa fa-pencil fa-fw'></i>
  <% end %>

  <%= link_to project_copy_key_path(@project, key), class: 'keys-actions', title: t('key.title.copy') do %>
    <i class='fa fa-files-o fa-fw'></i>
  <% end %>

  <%= link_to project_key_path(@project, key), class: 'keys-actions', data: {confirm: t('confirm.key.delete')}, method: :delete, title: t('key.title.delete') do %>
    <i class='fa fa-trash fa-fw'></i>
  <% end %>
<% end %>

<a href="#" class="keys-actions vault-copy-link" data-key-id="<%= key.id %>" title="<%= t('key.btn.copy_link') %>">
  <i class='fa fa-link fa-fw'></i>
</a>
