<%= form_for key, url: { controller: :keys, action: action }, html: { multipart: true } do |f| %>
  <div class='box tabular'>
   <div class="vault-form-cols">
    <div class="vault-form-col vault-form-col-main">
    <p><%= f.label :name, t('key.attr.name') %>
    <% if User.current.allowed_to?(:edit_keys, @project) %>
      <%= f.text_field :name %></p>
    <% else %>
      <%= f.text_field :name,:readonly => true %></p>
    <% end %>

    <p><%= f.label :login, t('key.attr.login') %>
    <% if User.current.allowed_to?(:edit_keys, @project) %>
      <%= f.text_field :login %></p>
    <% else %>
      <%= f.text_field :login,:readonly => true %></p>
    <% end %>

    <p><%= f.label :url, t('key.attr.url') %>
    <% if User.current.allowed_to?(:edit_keys, @project) %>
      <%= f.text_field :url %></p>
    <% else %>
      <%= f.text_field :url,:readonly => true %></p>
    <% end %>

    <p><%= f.label :type %>
    <%= f.select :type, key_types %></p>

    <p><%= f.label :body, t('key.attr.body') %>
    <% if User.current.allowed_to?(:edit_keys, @project) %>
      <%= f.text_field :body %></p>
    <% else %>
      <%= f.text_field :body,:readonly => true %></p>
    <% end %>

    <p><%= f.label :tags, t('key.attr.tags') %>
    <%= f.text_field :tags, value: Vault::Tag.tags_to_string(key.tags), class: 'autocomplete' %></p>

    <div class="vault-attachments tabular">
      <p class="vault-attachments-head"><label class="vault-attachments-label"><%= t('key.attr.attachments') %></label></p>
      <% if key.persisted? %>
        <% key.vault_attachments.order(:id).each do |att| %>
          <div class="vault-attachment-row">
            <%= link_to (att.filename.presence || "file ##{att.id}"), project_download_key_attachment_path(@project, att), class: 'icon icon-file' %>
            <% if User.current.allowed_to?(:edit_keys, @project) %>
              <%= text_field_tag "attachment_comments[#{att.id}]", att.comment, placeholder: t('key.attachment.comment'), class: 'vault-attachment-comment' %>
              <label class="vault-attachment-del"><%= check_box_tag 'attachment_remove[]', att.id %> <%= t('key.attachment.delete') %></label>
            <% elsif att.comment.present? %>
              <span class="vault-attachment-comment-ro"><%= att.comment %></span>
            <% end %>
          </div>
        <% end %>
      <% end %>
      <% if User.current.allowed_to?(:edit_keys, @project) %>
        <div id="vault-new-attachments">
          <div class="vault-new-attachment">
            <%= file_field_tag 'new_files[]' %>
            <%= text_field_tag 'new_comments[]', nil, placeholder: t('key.attachment.comment'), class: 'vault-attachment-comment' %>
          </div>
        </div>
        <p><a href="#" id="vault-add-attachment" class="icon icon-add">+ <%= t('key.attachment.add') %></a></p>
      <% end %>
    </div>
    </div>

    <div class="vault-form-col vault-form-col-aside">
    <p><%= f.label :comment, t('key.attr.comment') %>
    <% if User.current.allowed_to?(:edit_keys, @project) %>
      <%= f.text_area :comment, class: 'wiki-edit' %></p>
    <% else %>
      <%= f.text_area :comment, class: 'wiki-edit',:readonly => true %></p>
    <% end %>

    <% if User.current.allowed_to?(:manage_whitelist_keys, @project) %>
      <% whitelisted = @key.whitelist.split(",") %>
      <% members = @project.memberships.active.sort.map(&:principal) %>
      <div id="vault_whitelist">
        <p class="vault-acl-head"><label><%= t('key.attr.whitelist') %></label></p>
        <div class="vault-acl">
          <% members.each do |member| %>
            <label class="vault-acl-item">
              <%= check_box_tag 'whitelist[]', member.id.to_s, whitelisted.include?(member.id.to_s), id: nil %>
              <%= member %>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>
    </div>
   </div>
  </div>

  <% if User.current.allowed_to?(:edit_keys, @project) %>
    <%= f.submit t('button_save') %>
  <% else %>

  <% end %>
<% end %>
